# ====== Chung ======
CITY_ID=hanoi
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# ====== Sensor ======
PUBLISH_INTERVAL=5

# ====== InfluxDB (v2) ======
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=air
INFLUXDB_BUCKET=air_quality
INFLUXDB_TOKEN=super-secret-admin-token
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin12345

# ====== Grafana ======
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ====== ThingsBoard Cloud ======
TB_HOST=thingsboard.cloud
TB_PORT=1883
TB_GATEWAY_TOKEN=PUT_YOUR_GATEWAY_TOKEN_HERE
TB_ENABLED=false
